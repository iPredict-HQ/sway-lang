# iPredict Frontend – Fuel Testnet Configuration
# Copy this file to .env.local and fill in the values

# Fuel Provider URL (GraphQL endpoint)
NEXT_PUBLIC_FUEL_PROVIDER_URL=https://testnet.fuel.network/v1/graphql

# Deployed Contract IDs (replace with actual deployed addresses)
NEXT_PUBLIC_MARKET_CONTRACT_ID=
NEXT_PUBLIC_TOKEN_CONTRACT_ID=
NEXT_PUBLIC_REFERRAL_CONTRACT_ID=
NEXT_PUBLIC_LEADERBOARD_CONTRACT_ID=

# Admin address (deployer wallet B256 address)
NEXT_PUBLIC_ADMIN_ADDRESS=

# App URL (used for OG meta tags and canonical links)
NEXT_PUBLIC_APP_URL=https://ipredict.fuel.network
